---
import PublicLayout from '../layouts/PublicLayout.astro'
---

<PublicLayout
  title="Careers | Hyche International Management"
  description="Career opportunities at Hyche International Management — boutique NIL representation agency."
>
  <main class="coming-main">
    <div class="coming-inner">
      <p class="eyebrow">Careers · Coming Soon</p>
      <h1 class="headline">Building the<br/>Team.</h1>
      <p class="body">
        Hyche International Management is boutique by design. We hire slowly and intentionally. If you think you're a fit for the team, reach out directly — we'd rather meet you than read a resume.
      </p>
      <a href="/contact" class="cta-btn">Get In Touch →</a>
    </div>
  </main>
</PublicLayout>

<style>
  .coming-main {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px;
  }
  .coming-inner {
    max-width: 560px;
    text-align: center;
  }
  .eyebrow {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.32em;
    color: var(--color-accent);
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 5vw, 72px);
    line-height: 0.95;
    color: var(--color-chrome);
    margin-bottom: 24px;
  }
  .body {
    font-family: 'DM Sans', sans-serif;
    font-size: 17px;
    color: var(--color-silver);
    line-height: 1.75;
    margin-bottom: 32px;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 0.88rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: #fff;
    background: linear-gradient(180deg, #F4A060 0%, #E06828 30%, #C85010 60%, #8B3008 85%, #A04020 100%);
    padding: 14px 32px;
    border-radius: 4px;
    border: 1px solid rgba(232,138,26,0.3);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.3), 0 4px 20px rgba(200,80,16,0.4);
    transition: opacity 150ms;
  }
  .cta-btn:hover { opacity: 0.88; }
</style>
