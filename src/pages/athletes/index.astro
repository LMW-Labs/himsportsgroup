---
import PublicLayout from '../../layouts/PublicLayout.astro'

const sports = [
  {
    key: 'basketball',
    label: 'Basketball',
    path: '/athletes/basketball',
    description:
      'From high-major college programs to NBA Draft prospects, we navigate NIL deals, endorsements, and professional transition for the next generation of hoopers.',
    accent: '#1A72E8',
  },
  {
    key: 'football',
    label: 'Football',
    path: '/athletes/football',
    description:
      'Elite football talent at every level — CFB standouts, NFL Draft prospects, and active professionals. We handle contracts, NIL, and brand building end to end.',
    accent: '#C85010',
  },
  {
    key: 'track',
    label: 'Track & Field',
    path: '/athletes/track',
    description:
      'Track and field athletes have unique NIL windows and sponsorship opportunities. We specialize in maximizing value before and after collegiate careers.',
    accent: '#1A72E8',
  },
  {
    key: 'nil',
    label: 'NIL Practice',
    path: '/athletes/nil',
    description:
      'Our dedicated NIL division structures collective agreements, brand deals, content licensing, and long-term financial planning for student athletes at every level.',
    accent: '#C85010',
  },
  {
    key: 'other',
    label: 'Other Sports',
    path: '/athletes/other',
    description:
      'Baseball, soccer, swimming, golf, and beyond — if you compete at a high level, we have the infrastructure to support your career and monetize your brand.',
    accent: '#1A72E8',
  },
]
---

<PublicLayout
  title="Athletes | Hyche International Management Sports Group"
  description="Hyche International Management Sports Group represents elite athletes across NIL, collegiate, and professional sports. Explore our basketball, football, and track & field rosters."
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hero-inner">
      <div class="split-type">
        <span class="split-solid">ATHLETE</span>
        <span class="split-outline">REPRESENTATION</span>
      </div>
      <p class="hero-body">
        Representing the next generation of elite athletes&nbsp;—&nbsp;from NIL to the pros.
      </p>
    </div>
  </section>

  <!-- Sub-nav -->
  <nav class="subnav">
    <div class="subnav-inner">
      <a href="/athletes" class="subnav-link active">ALL</a>
      <span class="subnav-sep">/</span>
      <a href="/athletes/basketball" class="subnav-link">BASKETBALL</a>
      <span class="subnav-sep">/</span>
      <a href="/athletes/football" class="subnav-link">FOOTBALL</a>
      <span class="subnav-sep">/</span>
      <a href="/athletes/track" class="subnav-link">TRACK &amp; FIELD</a>
      <span class="subnav-sep">/</span>
      <a href="/athletes/nil" class="subnav-link">NIL</a>
      <span class="subnav-sep">/</span>
      <a href="/athletes/other" class="subnav-link">OTHER</a>
    </div>
  </nav>

  <!-- Philosophy -->
  <section class="philosophy">
    <div class="philosophy-inner reveal">
      <p class="eyebrow">Our Philosophy</p>
      <p class="philosophy-body">
        Representing talent is the foundation of our business. We take a consultative
        approach&nbsp;—&nbsp;from NIL to the pros, we build game plans for every stage
        of every career. No cookie-cutter deals. No rushed negotiations. Every athlete
        is a portfolio of one.
      </p>
      <div class="rule-wrap" aria-hidden="true">
        <div class="rule-line"></div>
        <div class="rule-diamond"></div>
        <div class="rule-line"></div>
      </div>
    </div>
  </section>

  <!-- Sport Category Cards -->
  <section class="cards-section">
    <div class="container">
      <div class="cards-header">
        <h2 class="section-title">BY SPORT</h2>
        <a href="/athletes" class="view-all">View All Rosters →</a>
      </div>
      <div class="cards-grid">
        {sports.map(cat => (
          <a href={cat.path} class="sport-card reveal" data-accent={cat.accent}>
            <div class="card-top-line" style={`background:${cat.accent}`}></div>
            <div class="card-header">
              <h3 class="card-label">{cat.label}</h3>
              <span class="card-badge" style={`background:${cat.accent}20;color:${cat.accent};border:1px solid ${cat.accent}40`}>
                View Roster
              </span>
            </div>
            <p class="card-desc">{cat.description}</p>
            <p class="card-link">View Roster →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="cta-inner reveal">
      <p class="eyebrow">Ready to Work Together?</p>
      <h2 class="cta-title">APPLY FOR REPRESENTATION</h2>
      <p class="cta-body">
        We work with a select group of athletes at every stage of their career.
        Tell us about yourself and we'll reach out within 48 hours.
      </p>
      <a href="/contact" class="cta-btn">Apply for Representation →</a>
    </div>
  </section>

</PublicLayout>

<style>
  /* ── Hero ── */
  .hero {
    background-color: var(--color-bg);
    min-height: 72vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: 80px;
    position: relative;
    overflow: hidden;
    padding-top: 120px;
  }
  .hero-glow {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse 70% 60% at 30% 50%, rgba(26,114,232,0.12) 0%, transparent 70%);
  }
  .hero-grid {
    position: absolute; inset: 0; pointer-events: none;
    opacity: 0.025;
    background-image:
      linear-gradient(rgba(168,189,208,1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168,189,208,1) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .hero-inner {
    position: relative; z-index: 1;
    width: 100%; max-width: 1400px;
    margin: 0 auto;
    padding: 0 clamp(24px, 4vw, 96px);
  }
  .split-type {
    display: flex; flex-direction: column; gap: 0; margin-bottom: 32px;
  }
  .split-solid {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(80px, 13vw, 180px);
    line-height: 0.88;
    letter-spacing: 0.01em;
    color: var(--color-chrome);
    display: block;
  }
  .split-outline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(80px, 13vw, 180px);
    line-height: 0.88;
    letter-spacing: 0.01em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(168,189,208,0.4);
    display: block;
    text-align: right;
  }
  .hero-body {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(15px, 1.5vw, 18px);
    color: var(--color-silver);
    max-width: 480px;
    line-height: 1.6;
  }

  /* ── Sub-nav ── */
  .subnav {
    position: sticky; top: 72px; z-index: 20;
    background-color: rgba(10,12,16,0.97);
    border-bottom: 1px solid rgba(168,189,208,0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    overflow-x: auto;
  }
  .subnav-inner {
    display: flex; align-items: center;
    max-width: 1400px; margin: 0 auto;
    padding: 0 clamp(24px, 4vw, 96px);
  }
  .subnav-link {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(168,189,208,0.6);
    padding: 16px 12px;
    white-space: nowrap;
    position: relative;
    transition: color 200ms;
  }
  .subnav-link:hover,
  .subnav-link.active { color: var(--color-chrome); }
  .subnav-link.active::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--color-accent);
  }
  .subnav-sep {
    font-family: 'Rajdhani', sans-serif;
    color: rgba(168,189,208,0.2);
    font-size: 12px;
    padding: 0 4px;
    user-select: none;
  }

  /* ── Philosophy ── */
  .philosophy {
    padding: 80px 0 100px;
    background-color: var(--color-bg);
  }
  .philosophy-inner {
    max-width: 720px; margin: 0 auto; text-align: center;
    padding: 0 clamp(24px, 4vw, 96px);
  }
  .eyebrow {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700; font-size: 0.72rem;
    letter-spacing: 0.32em; color: var(--color-accent);
    text-transform: uppercase; margin-bottom: 24px;
  }
  .philosophy-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 18px; color: var(--color-silver);
    line-height: 1.75;
  }
  .rule-wrap {
    display: flex; align-items: center; justify-content: center; gap: 16px; margin-top: 40px;
  }
  .rule-line {
    height: 1px; width: 80px;
    background-color: rgba(168,189,208,0.15);
  }
  .rule-diamond {
    width: 6px; height: 6px;
    background: var(--color-accent);
    transform: rotate(45deg);
  }

  /* ── Cards ── */
  .cards-section {
    padding-bottom: 96px;
    background-color: var(--color-bg);
  }
  .container {
    max-width: 1400px; margin: 0 auto;
    padding: 0 clamp(24px, 4vw, 96px);
  }
  .cards-header {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 48px;
  }
  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(32px, 4vw, 56px);
    letter-spacing: 0.02em;
    color: var(--color-chrome);
  }
  .view-all {
    font-family: 'Rajdhani', sans-serif; font-weight: 700;
    font-size: 13px; letter-spacing: 0.15em; text-transform: uppercase;
    color: rgba(168,189,208,0.6); text-decoration: none;
    transition: color 200ms;
  }
  .view-all:hover { color: var(--color-accent); }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }
  .sport-card {
    position: relative; overflow: hidden;
    background-color: var(--color-surface);
    border: 1px solid rgba(168,189,208,0.08);
    padding: 40px;
    text-decoration: none;
    display: block;
    transition: border-color 220ms, transform 220ms, box-shadow 220ms;
  }
  .sport-card:hover {
    border-color: rgba(200,80,16,0.5);
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(200,80,16,0.12);
  }
  .card-top-line {
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    transform: scaleX(0); transform-origin: left;
    transition: transform 350ms ease-out;
  }
  .sport-card:hover .card-top-line { transform: scaleX(1); }
  .card-header {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;
    margin-bottom: 20px;
  }
  .card-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 5vw, 68px);
    letter-spacing: 0.02em; line-height: 1;
    color: var(--color-chrome);
  }
  .card-badge {
    font-family: 'Rajdhani', sans-serif; font-weight: 700;
    font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase;
    padding: 4px 10px; margin-top: 8px; flex-shrink: 0; white-space: nowrap;
  }
  .card-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px; color: var(--color-silver);
    line-height: 1.7; margin-bottom: 24px;
  }
  .card-link {
    font-family: 'Rajdhani', sans-serif; font-weight: 700;
    font-size: 14px; letter-spacing: 0.1em;
    color: var(--color-chrome);
    transition: color 200ms;
  }
  .sport-card:hover .card-link { color: var(--color-accent); }

  /* ── CTA ── */
  .cta-section {
    padding: 96px 0;
    background: linear-gradient(135deg, #0E1220 0%, #0A0C10 100%);
    border-top: 1px solid rgba(168,189,208,0.08);
    position: relative; overflow: hidden;
  }
  .cta-glow {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse 50% 80% at 50% 50%, rgba(200,80,16,0.07) 0%, transparent 70%);
  }
  .cta-inner {
    position: relative; z-index: 1;
    max-width: 640px; margin: 0 auto; text-align: center;
    padding: 0 clamp(24px, 4vw, 48px);
  }
  .cta-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 6vw, 80px);
    letter-spacing: 0.02em;
    color: var(--color-chrome);
    margin-bottom: 24px;
  }
  .cta-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px; color: var(--color-silver);
    line-height: 1.75; margin-bottom: 40px;
    max-width: 480px; margin-left: auto; margin-right: auto;
  }
  .cta-btn {
    display: inline-block;
    font-family: 'Rajdhani', sans-serif; font-weight: 700;
    font-size: 0.88rem; letter-spacing: 0.15em; text-transform: uppercase;
    text-decoration: none; color: #fff;
    background-color: #C85010;
    padding: 16px 40px;
    transition: opacity 150ms;
  }
  .cta-btn:hover { opacity: 0.9; }

  /* ── Reveal animation ── */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.visible { opacity: 1; transform: none; }
</style>

<script>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }),
    { threshold: 0.1, rootMargin: '-40px' }
  )
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el))
</script>
