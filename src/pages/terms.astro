    padding: 24px;
    background-color: rgba(200,80,16,0.08);
    border: 1px solid rgba(200,80,16,0.2);
    border-left: 3px solid var(--color-accent);
  }
  .draft-label {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    color: var(--color-accent);
