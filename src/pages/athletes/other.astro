---
import PublicLayout from '../../layouts/PublicLayout.astro'
import AthleteFilters from '../../components/interactive/AthleteFilters'
import { supabase } from '../../lib/supabase/client'
import type { Athlete } from '../../lib/supabase/types'

let athletes: Athlete[] = []
let fetchError = false

try {
  const { data, error } = await supabase
    .from('athletes')
    .select('*')
    .eq('published', true)
    .order('name')

  if (error) {
    fetchError = true
  } else {
    const excluded = ['basketball', 'football', 'track']
    athletes = (data ?? []).filter(
      (a: Athlete) => !excluded.some(s => a.sport.toLowerCase().includes(s))
    )
  }
} catch {
  fetchError = true
}
---

<PublicLayout
  title="Other Sports Roster | Hyche International Management Sports Group"
  description="Our other sports roster — NIL clients, pro prospects, and rising stars represented by Hyche International Management Sports Group across baseball, soccer, volleyball, and more."
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hero-inner">
      <div class="split-type">
        <span class="split-solid">OTHER</span>
        <span class="split-outline">SPORTS</span>
      </div>
      <p class="hero-body">
        From baseball to soccer to volleyball and beyond&nbsp;—&nbsp;we provide the same boutique
        representation and brand-building expertise across every sport.
      </p>
    </div>
  </section>

  <!-- Sub-nav -->
  <nav class="subnav">
    <div class="subnav-inner">
      <a href="/athletes" class="subnav-link">ALL</a>
      <span class="subnav-sep">/</span>
      <a href="/athletes/basketball" class="subnav-link">BASKETBALL</a>
      <span class="subnav-sep">/</span>
      <a href="/athletes/football" class="subnav-link">FOOTBALL</a>
      <span class="subnav-sep">/</span>
      <a href="/athletes/track" class="subnav-link">TRACK &amp; FIELD</a>
      <span class="subnav-sep">/</span>
      <a href="/athletes/nil" class="subnav-link">NIL</a>
      <span class="subnav-sep">/</span>
      <a href="/athletes/other" class="subnav-link active">OTHER</a>
    </div>
  </nav>

  <!-- Roster section -->
  <section class="roster-section">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="section-title">OUR OTHER SPORT ATHLETES</h2>
      </div>

      {(fetchError || athletes.length === 0) ? (
        <div class="empty-state reveal">
          <div class="empty-icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <circle cx="24" cy="24" r="22" stroke="rgba(168,189,208,0.15)" stroke-width="2"/>
              <path d="M24 14v10l6 4" stroke="rgba(168,189,208,0.3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="empty-label">COMING SOON</p>
          <p class="empty-title">OTHER SPORTS ROSTER LOADING</p>
          <p class="empty-body">
            We're building something special. Our other sports roster is being curated and will be
            live shortly. In the meantime, reach out to learn about representation.
          </p>
          <a href="/contact" class="empty-cta">Inquire About Representation →</a>
        </div>
      ) : (
        <div class="reveal">
          <AthleteFilters athletes={athletes} client:load />
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="cta-inner reveal">
      <p class="eyebrow">Join the Program</p>
      <h2 class="cta-title">APPLY FOR REPRESENTATION</h2>
      <p class="cta-body">
        No matter the sport, we work with a select group of athletes at every stage of their career.
        Tell us about yourself and we'll reach out within 48 hours.
      </p>
      <a href="/contact" class="cta-btn">Apply for Representation →</a>
    </div>
  </section>

</PublicLayout>

<style>
  /* ── Hero ── */
  .hero {
    background-color: var(--color-bg);
    min-height: 72vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: 80px;
    position: relative;
    overflow: hidden;
    padding-top: 120px;
  }
  .hero-glow {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse 70% 60% at 30% 50%, rgba(26,114,232,0.12) 0%, transparent 70%);
  }
  .hero-grid {
    position: absolute; inset: 0; pointer-events: none;
    opacity: 0.025;
    background-image:
      linear-gradient(rgba(168,189,208,1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168,189,208,1) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .hero-inner {
    position: relative; z-index: 1;
    width: 100%; max-width: 1400px;
    margin: 0 auto;
    padding: 0 clamp(24px, 4vw, 96px);
  }
  .split-type {
    display: flex; flex-direction: column; gap: 0; margin-bottom: 32px;
  }
  .split-solid {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(72px, 12vw, 168px);
    line-height: 0.88;
    letter-spacing: 0.01em;
    color: var(--color-chrome);
    display: block;
  }
  .split-outline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(72px, 12vw, 168px);
    line-height: 0.88;
    letter-spacing: 0.01em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(168,189,208,0.4);
    display: block;
    text-align: right;
  }
  .hero-body {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(15px, 1.5vw, 18px);
    color: var(--color-silver);
    max-width: 480px;
    line-height: 1.6;
  }

  /* ── Sub-nav ── */
  .subnav {
    position: sticky; top: 72px; z-index: 20;
    background-color: rgba(10,12,16,0.97);
    border-bottom: 1px solid rgba(168,189,208,0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    overflow-x: auto;
  }
  .subnav-inner {
    display: flex; align-items: center;
    max-width: 1400px; margin: 0 auto;
    padding: 0 clamp(24px, 4vw, 96px);
  }
  .subnav-link {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(168,189,208,0.6);
    padding: 16px 12px;
    white-space: nowrap;
    position: relative;
    transition: color 200ms;
  }
  .subnav-link:hover,
  .subnav-link.active { color: var(--color-chrome); }
  .subnav-link.active::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--color-accent);
  }
  .subnav-sep {
    font-family: 'Rajdhani', sans-serif;
    color: rgba(168,189,208,0.2);
    font-size: 12px;
    padding: 0 4px;
    user-select: none;
  }

  /* ── Roster ── */
  .roster-section {
    padding: 80px 0 96px;
    background-color: var(--color-bg);
  }
  .container {
    max-width: 1400px; margin: 0 auto;
    padding: 0 clamp(24px, 4vw, 96px);
  }
  .section-header {
    margin-bottom: 48px;
  }
  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(32px, 4vw, 56px);
    letter-spacing: 0.02em;
    color: var(--color-chrome);
  }

  /* ── Empty State ── */
  .empty-state {
    max-width: 480px; margin: 0 auto;
    text-align: center;
    padding: 80px 24px;
    border: 1px solid rgba(168,189,208,0.08);
    background: var(--color-surface);
    border-radius: 4px;
  }
  .empty-icon {
    margin-bottom: 24px;
    opacity: 0.6;
  }
  .empty-label {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    color: var(--color-accent);
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .empty-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(28px, 4vw, 44px);
    letter-spacing: 0.03em;
    color: var(--color-chrome);
    margin-bottom: 20px;
    line-height: 1;
  }
  .empty-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    color: var(--color-silver);
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .empty-cta {
    display: inline-block;
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    color: #fff;
    background-color: var(--color-accent);
    padding: 14px 32px;
    transition: opacity 150ms;
  }
  .empty-cta:hover { opacity: 0.88; }

  /* ── CTA ── */
  .cta-section {
    padding: 96px 0;
    background: linear-gradient(135deg, #0E1220 0%, #0A0C10 100%);
    border-top: 1px solid rgba(168,189,208,0.08);
    position: relative; overflow: hidden;
  }
  .cta-glow {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse 50% 80% at 50% 50%, rgba(200,80,16,0.07) 0%, transparent 70%);
  }
  .cta-inner {
    position: relative; z-index: 1;
    max-width: 640px; margin: 0 auto; text-align: center;
    padding: 0 clamp(24px, 4vw, 48px);
  }
  .eyebrow {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700; font-size: 0.72rem;
    letter-spacing: 0.32em; color: var(--color-accent);
    text-transform: uppercase; margin-bottom: 24px;
  }
  .cta-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 6vw, 80px);
    letter-spacing: 0.02em;
    color: var(--color-chrome);
    margin-bottom: 24px;
  }
  .cta-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px; color: var(--color-silver);
    line-height: 1.75; margin-bottom: 40px;
    max-width: 480px; margin-left: auto; margin-right: auto;
  }
  .cta-btn {
    display: inline-block;
    font-family: 'Rajdhani', sans-serif; font-weight: 700;
    font-size: 0.88rem; letter-spacing: 0.15em; text-transform: uppercase;
    text-decoration: none; color: #fff;
    background-color: #C85010;
    padding: 16px 40px;
    transition: opacity 150ms;
  }
  .cta-btn:hover { opacity: 0.9; }

  /* ── Reveal ── */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.visible { opacity: 1; transform: none; }
</style>

<script>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }),
    { threshold: 0.1, rootMargin: '-40px' }
  )
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el))
</script>
