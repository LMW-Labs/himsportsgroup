# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Project URL
PUBLIC_SUPABASE_URL=https://yuzwbglugboymetybbkh.supabase.co

# Anon / publishable key — safe to expose client-side (enforced by RLS)
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_l6gAJ1EhK9P5ViWhCKtHQg_2OvThqj1

# Service role key — SERVER ONLY, never expose to clients
SUPABASE_SERVICE_ROLE_KEY=<from Supabase dashboard → Settings → API>

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<from @BotFather>

# Google Custom Search
GOOGLE_CSE_ID=b17fff82d1f59459c
# Paste the full service account JSON minified to a single line
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...", ...}

# Vercel deploy hook — create under Project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
