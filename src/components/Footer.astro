---
const year = new Date().getFullYear()

const athletes = [
  { href: '/athletes',          label: 'Athletes Overview' },
  { href: '/athletes/basketball', label: 'Basketball' },
  { href: '/athletes/nil',      label: 'NIL Practice' },
  { href: '/contact',           label: 'Apply for Representation' },
]

const agency = [
  { href: '/about',       label: 'About Us' },
  { href: '/about/team',  label: 'Our Team' },
  { href: '/news',        label: 'News & Insights' },
  { href: '/careers',     label: 'Careers' },
  { href: '/contact',     label: 'Contact' },
  { href: '/brands',      label: 'For Brands' },
]
---

<footer style="background-color:#0E1220;border-top:1px solid rgba(168,189,208,0.10)">
  <div style="max-width:1280px;margin:0 auto;padding:80px 24px 0">

    <!-- Grid -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:48px">

      <!-- Col 1: Brand -->
      <div>
        <div style="margin-bottom:16px">
          <img
            src="/logo.png"
            alt="Hyche International Management Sports Group"
            style="height:40px;width:auto;display:block"
          />
        </div>
        <p style="font-family:'Rajdhani',sans-serif;font-style:italic;font-size:0.95rem;color:#A8BDD0;margin-bottom:12px;line-height:1.5">
          Your Name. Your Brand. Your Future.
        </p>
        <p style="font-family:'DM Sans',sans-serif;font-size:0.8rem;color:rgba(168,189,208,0.55);line-height:1.7;margin-bottom:24px;max-width:260px">
          Elite sports management and NIL consulting for the next generation of athletes and the brands that partner with them.
        </p>

        <!-- Social icons -->
        <div style="display:flex;gap:16px;align-items:center">
          <a href="#" aria-label="Instagram" class="footer-social">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a href="#" aria-label="Twitter / X" class="footer-social">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="#" aria-label="TikTok" class="footer-social">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.17 8.17 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/>
            </svg>
          </a>
          <a href="#" aria-label="YouTube" class="footer-social">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
          <a href="#" aria-label="LinkedIn" class="footer-social">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Athletes -->
      <div>
        <div class="footer-col-heading">Athletes</div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px">
          {athletes.map(({ href, label }) => (
            <li><a href={href} class="footer-link">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Agency -->
      <div>
        <div class="footer-col-heading">Agency</div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px">
          {agency.map(({ href, label }) => (
            <li><a href={href} class="footer-link">{label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="border-top:1px solid rgba(168,189,208,0.10);margin-top:64px;padding-top:32px;padding-bottom:32px;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:16px">
      <span class="footer-meta">&copy; {year} Hyche International Management. All rights reserved.</span>
      <div style="display:flex;gap:20px;align-items:center">
        <a href="/privacy" class="footer-meta footer-legal">Privacy Policy</a>
        <span style="color:rgba(168,189,208,0.25);font-size:0.7rem">|</span>
        <a href="/terms" class="footer-meta footer-legal">Terms of Service</a>
      </div>
      <span class="footer-meta" style="letter-spacing:0.08em">Jackson, MS &middot; Nationwide</span>
    </div>

  </div>
</footer>

<style>
  .footer-col-heading {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #D8E8F4;
    margin-bottom: 16px;
  }
  .footer-link {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: rgba(168,189,208,0.70);
    text-decoration: none;
    display: inline-block;
    transition: color 150ms;
  }
  .footer-link:hover { color: #F0F4F8; }
  .footer-social {
    color: #A8BDD0;
    line-height: 0;
    transition: color 150ms;
  }
  .footer-social:hover { color: #F0F4F8; }
  .footer-meta {
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.8rem;
    color: rgba(168,189,208,0.50);
  }
  .footer-legal {
    text-decoration: none;
    transition: color 150ms;
  }
  .footer-legal:hover { color: #A8BDD0; }
</style>
